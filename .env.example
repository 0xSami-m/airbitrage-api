# ── Mailgun (inbound email / 2FA) ──────────────────────────────────────────────
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_SANDBOX_DOMAIN=sandboxXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.mailgun.org

# ── Aeroplan ───────────────────────────────────────────────────────────────────
AEROPLAN_DEFAULT_PASSWORD=SecurePass123!

# ── Stripe (payments + virtual cards) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...          # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...        # from Stripe dashboard → Webhooks
STRIPE_CARDHOLDER_ID=ich_...           # run get_or_create_cardholder() once to get this

# Cardholder billing address (used when creating the Stripe Issuing cardholder)
STRIPE_CARDHOLDER_EMAIL=billing@yourtravelagency.com
STRIPE_CARDHOLDER_PHONE=+12025551234
STRIPE_CARDHOLDER_NAME=Travel Agent Services
STRIPE_BILLING_LINE1=123 Main St
STRIPE_BILLING_CITY=New York
STRIPE_BILLING_STATE=NY
STRIPE_BILLING_ZIP=10001
STRIPE_BILLING_COUNTRY=US

# Pricing
SERVICE_FEE_CENTS=3500                 # $35 service fee per booking
MILES_CPP_USD=0.0144                   # cost per mile in USD (update with current promo)

# Stripe redirect URLs (update with your production frontend URL)
STRIPE_SUCCESS_URL=http://localhost:5174/booking-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5174/booking-cancelled

# ── Fallback card (for testing without Stripe Issuing enabled) ─────────────────
FALLBACK_CARD_NUMBER=
FALLBACK_CARD_EXPIRY=
FALLBACK_CARD_CVV=
FALLBACK_CARD_NAME=
